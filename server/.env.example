# ==============================================
# Backend Environment Variables (.env.example)
# ==============================================
# Copy file này thành .env và điền giá trị thực tế

# Server
PORT=3000
NODE_ENV=development

# Database (Prisma)
# Local: mysql://root:rootpassword@localhost:3306/wms_db
# Railway: mysql://root:xxxxx@autorack.proxy.rlwy.net:12345/railway
DATABASE_URL=mysql://root:rootpassword@localhost:3306/wms_db

# JWT Authentication
JWT_SECRET=wms-super-secret-jwt-key-change-this-in-production-2026
JWT_EXPIRES_IN=7d

# CORS - Frontend URL
# Local: http://localhost:5173
# Production: https://your-app.vercel.app
CLIENT_URL=http://localhost:5173
